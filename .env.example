# AI教育平台 - 环境变量配置
# =============================================
# 自托管模式：复制此文件为 .env.local 并填写配置

# === 数据库 ===
# 数据库类型：sqlite（默认，开发推荐）| postgresql（生产推荐）
DATABASE_PROVIDER=sqlite

# SQLite 本地数据库（开发环境，无需额外配置）
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL 连接（取消注释以下行以切换到 PostgreSQL）
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://username:password@localhost:5432/ai_edu_platform?schema=public"

# === NextAuth 认证密钥 ===
# 生成密钥：openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"
# 应用基础 URL（生产环境请改为实际域名，如 https://your-domain.com）
NEXTAUTH_URL="http://localhost:3000"

# === 大模型配置 ============================
# 选择方式：deepseek | qwen | openai | ollama | custom
LLM_PROVIDER=deepseek

# DeepSeek API（推荐，成本最低）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 通义千问 API
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama 本地模型（无需 API Key，需先安装 Ollama）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# 自定义 OpenAI 兼容端点
CUSTOM_API_KEY=sk-your-custom-key
CUSTOM_BASE_URL=https://your-custom-endpoint.com/v1
CUSTOM_MODEL=your-model-name

# === 模型参数（可选）===
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
LLM_TOP_P=0.85

# === 其他服务（可选，自托管可按需配置）===
# 语音识别 Whisper API（可选）
# WHISPER_API_URL=http://localhost:9000

# Redis 缓存（可选，启用后显著提升余额查询/扣减和限流性能）
# 本地开发默认连接 localhost:6379，生产环境请使用 Redis Cloud 或自建实例
# 不填则自动降级为纯数据库模式，不影响核心功能
REDIS_URL=redis://localhost:6379

# === 管理后台（可选）===
# 管理后台 IP 白名单（逗号分隔的 IP 列表，留空则不启用白名单）
# 示例：192.168.1.100,10.0.0.0/24
ADMIN_IP_WHITELIST=""
