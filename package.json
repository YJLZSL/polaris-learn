{
  "name": "polaris-learn",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "npx prisma db push",
    "db:seed": "npx prisma db seed",
    "db:migrate-pg": "npx tsx scripts/migrate-to-pg.ts",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:start": "electron .",
    "electron:icon": "node scripts/generate-icons.js",
    "android:init": "npx cap init Polaris com.polaris.learn --web-dir=out && npx cap add android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "npm run build && npx cap sync android",
    "android:dev": "npm run dev & npx cap run android",
    "version:check": "node -e \"console.log(require('./package.json').version)\""
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.2",
    "@capacitor/core": "^8.3.2",
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.16",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "electron-serve": "^3.0.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.18.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.polaris.learn",
    "productName": "Polaris 北极星学习平台",
    "directories": {
      "output": "electron-dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon-512.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon-512.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      ".next/**/*",
      "node_modules/**/*",
      "public/**/*",
      "package.json",
      "electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "YJLZSL",
        "repo": "polaris-learn"
      }
    ]
  }
}
