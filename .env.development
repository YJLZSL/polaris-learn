# 开发环境配置 (Development)
# 此文件可安全提交到仓库,仅含开发占位值

# 数据库 (开发用 SQLite)
DATABASE_URL="file:./dev.db"

# NextAuth
AUTH_SECRET="dev-only-secret-please-replace-in-production-32chars-min"
NEXTAUTH_URL="http://localhost:3000"

# Capacitor 开发服务器指向本地
CAPACITOR_SERVER_URL="http://localhost:3000"

# Android APK 下载地址占位(开发环境留空)
ANDROID_DOWNLOAD_URL=""
